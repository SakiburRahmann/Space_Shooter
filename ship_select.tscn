content_margin_left = 40.0
content_margin_top = 14.0
content_margin_right = 40.0
content_margin_bottom = 14.0

[node name="ShipSelect" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
