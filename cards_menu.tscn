[gd_scene format=3 uid="uid://cardsmnu"]

[ext_resource type="Script" path="res://cards_menu.gd" id="1_c"]
[ext_resource type="Shader" path="res://grid_bg.gdshader" id="2_s"]

[sub_resource type="ShaderMaterial" id="ShaderMaterial_bg"]
shader = ExtResource("2_s")

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_upg"]
