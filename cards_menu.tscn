anchor_bottom = 1.0
offset_left = 60.0
offset_top = 100.0
offset_right = -60.0
offset_bottom = -120.0
theme_override_constants/separation = 40

[node name="Scroll" type="ScrollContainer" parent="HBox"]
custom_minimum_size = Vector2(350, 0)
layout_mode = 2

[node name="List" type="VBoxContainer" parent="HBox/Scroll"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 10

[node name="Details" type="VBoxContainer" parent="HBox"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 20
alignment = 1

[node name="Preview" type="Control" parent="HBox/Details"]
custom_minimum_size = Vector2(0, 180)
layout_mode = 2

[node name="IconLabel" type="Label" parent="HBox/Details/Preview"]
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -100.0
offset_top = -100.0
offset_right = 100.0
offset_bottom = 100.0
